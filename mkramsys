#!/bin/bash
# mkramsys — Unified CLI for building RAM-based Debian systems
#
# Usage: mkramsys [-w WORKSPACE] <command> [options]

set -e

PROG=${0##*/}
LIBDIR="$(dirname "$(readlink -f "$0")")/lib"

usage() {
    cat <<EOF
Usage: $PROG [-w DIR] <command> [options]

Commands:
  init      Create a standalone Debian squashfs image (debootstrap)
  open      Start a session on an existing squashfs
  driver    Detect host firmware and install matching packages
  install   Install packages in the image
  shell     Interactive chroot, run a command, or execute a script
  build     Snapshot current state as squashfs (non-destructive)
  commit    Finalize: cleansys + squashfs + close session
  reset     Discard overlay changes (keep session)
  close     Delete session entirely

Options:
  -w DIR    Session directory (override automatic session discovery)
  -h        Show this help
EOF
    exit "${1:-0}"
}

# ── Global option parsing ─────────────────────────────────────────────────────

while getopts ":w:h" opt; do
    case $opt in
        w) export WORKSPACE="$OPTARG" ;;
        h) usage 0 ;;
        :) echo "error: -$OPTARG requires an argument" >&2; usage 1 ;;
        *) echo "error: unknown option -$OPTARG" >&2; usage 1 ;;
    esac
done
shift $((OPTIND - 1))

COMMAND="${1:-}"
[ -z "$COMMAND" ] && usage 1
shift

# Resolve WORKSPACE to absolute path only if explicitly set via -w
if [ -n "${WORKSPACE:-}" ]; then
    WORKSPACE="$(readlink -f "$WORKSPACE")"
    export WORKSPACE
fi

# ── Source shared library ─────────────────────────────────────────────────────

# shellcheck source=lib/common.sh
. "$LIBDIR/common.sh"

# ── Dispatch to subcommand ────────────────────────────────────────────────────

CMD_SCRIPT="$LIBDIR/cmd_${COMMAND}.sh"

if [ ! -f "$CMD_SCRIPT" ]; then
    echo "error: unknown command '$COMMAND'" >&2
    usage 1
fi

# shellcheck source=/dev/null
. "$CMD_SCRIPT"

cmd_run "$@"
