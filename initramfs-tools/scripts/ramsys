# Local filesystem mounting			-*- shell-script -*-
# shellcheck shell=sh

# Parse ramsys boot parameters from kernel command line
_ramsys_parse_cmdline()
{
	RAMSYSSRC=
	RAMSYSDIR=
	RAMSYSSRCFSTYPE=
	RAMSYSSRCFLAGS=
	# shellcheck disable=SC2013
	for x in $(cat /proc/cmdline); do
		case $x in
		ramsys.src=*)        RAMSYSSRC="${x#ramsys.src=}" ;;
		ramsys.dir=*)        RAMSYSDIR="${x#ramsys.dir=}" ;;
		ramsys.src.fstype=*) RAMSYSSRCFSTYPE="${x#ramsys.src.fstype=}" ;;
		ramsys.src.flags=*)  RAMSYSSRCFLAGS="${x#ramsys.src.flags=}" ;;
		esac
	done
}

ramsys_top()
{
	if [ "${ramsys_top_used}" != "yes" ]; then
		[ "${quiet?}" != "y" ] && log_begin_msg "Running /scripts/ramsys-top"
		run_scripts /scripts/ramsys-top
		[ "$quiet" != "y" ] && log_end_msg
	fi
	ramsys_top_used=yes
}

ramsys_block()
{
	[ "${quiet?}" != "y" ] && log_begin_msg "Running /scripts/ramsys-block"
	run_scripts /scripts/ramsys-block "$@"
	[ "$quiet" != "y" ] && log_end_msg
}

ramsys_premount()
{
	if [ "${ramsys_premount_used}" != "yes" ]; then
		[ "${quiet?}" != "y" ] && log_begin_msg "Running /scripts/ramsys-premount"
		run_scripts /scripts/ramsys-premount
		[ "$quiet" != "y" ] && log_end_msg
	fi
	ramsys_premount_used=yes
}

ramsys_bottom()
{
	if [ "${ramsys_premount_used}" = "yes" ] || [ "${ramsys_top_used}" = "yes" ]; then
		[ "${quiet?}" != "y" ] && log_begin_msg "Running /scripts/ramsys-bottom"
		run_scripts /scripts/ramsys-bottom
		[ "$quiet" != "y" ] && log_end_msg
	fi
	ramsys_premount_used=no
	ramsys_top_used=no
}

# $1=device ID to mount
# $2=optionname (for root and etc)
# $3=panic if device is missing (true or false, default: true)
# Sets $DEV to the resolved device node
ramsys_device_setup()
{
	local dev_id="$1"
	local name="$2"
	local may_panic="${3:-true}"
	local real_dev
	local time_elapsed
	local count

	wait_for_udev 10

	# Load ubi with the correct MTD partition and return since fstype
	# doesn't work with a char device like ubi.
	if [ -n "$UBIMTD" ]; then
		/sbin/modprobe ubi "mtd=$UBIMTD"
		DEV="${dev_id}"
		return
	fi

	# Don't wait for a device that doesn't have a corresponding
	# device in /dev and isn't resolvable by blkid (e.g. mtd0)
	if [ "${dev_id#/dev}" = "${dev_id}" ] &&
	   [ "${dev_id#*=}" = "${dev_id}" ]; then
		DEV="${dev_id}"
		return
	fi

	# If the root device hasn't shown up yet, give it a little while
	# to allow for asynchronous device discovery (e.g. USB).  We
	# also need to keep invoking the local-block scripts in case
	# there are devices stacked on top of those.
	if ! real_dev=$(resolve_device "${dev_id}") ||
	   ! get_fstype "${real_dev}" >/dev/null; then
		log_begin_msg "Waiting for ${name}"

		# Timeout is max(30, rootdelay) seconds (approximately)
		slumber=30
		if [ "${ROOTDELAY:-0}" -gt $slumber ]; then
			slumber=$ROOTDELAY
		fi

		while true; do
			sleep 1
			time_elapsed="$(time_elapsed)"

			ramsys_block "${dev_id}"

			# If mdadm's local-block script counts the
			# number of times it is run, make sure to
			# run it the expected number of times.
			while true; do
				if [ -f /run/count.mdadm.initrd ]; then
					count="$(cat /run/count.mdadm.initrd)"
				elif [ -n "${count}" ]; then
					# mdadm script deleted it; put it back
					count=$((count + 1))
					echo "${count}" >/run/count.mdadm.initrd
				else
					break
				fi
				if [ "${count}" -ge "${time_elapsed}" ]; then
					break;
				fi
				/scripts/local-block/mdadm "${dev_id}"
			done

			if real_dev=$(resolve_device "${dev_id}") &&
				get_fstype "${real_dev}" >/dev/null; then
				wait_for_udev 10
				log_end_msg 0
				break
			fi
			if [ "${time_elapsed}" -ge "${slumber}" ]; then
				log_end_msg 1 || true
				break
			fi
		done
	fi

	# We've given up, but we'll let the user fix matters if they can
	while ! real_dev=$(resolve_device "${dev_id}") ||
		  ! get_fstype "${real_dev}" >/dev/null; do
		if ! $may_panic; then
			echo "Gave up waiting for ${name}"
			return 1
		fi
		echo "Gave up waiting for ${name} device.  Common problems:"
		echo " - Boot args (cat /proc/cmdline)"
		echo "   - Check rootdelay= (did the system wait long enough?)"
		if [ "${name}" = root ]; then
			echo "   - Check root= (did the system wait for the right device?)"
		fi
		echo " - Missing modules (cat /proc/modules; ls /dev)"
		panic "ALERT!  ${dev_id} does not exist.  Dropping to a shell!"
	done

	DEV="${real_dev}"
}

ramsys_mount_root()
{
	_ramsys_parse_cmdline

	local mnt=/mnt
	local ramsys_mnt="$mnt/lower"
	local upperdir="$mnt/upper"
	local workdir="$mnt/work"
	local ramsys_src_mnt="$mnt/ramsys_src"
	local ramsys_dir_abs=
	local ramsys_dir_mem="${mnt}/rootfs.sqfs"

	ramsys_top

	mkdir "$mnt" && mount -t tmpfs none "$mnt" || panic "Setup $mnt failed."
	mkdir -p "$ramsys_src_mnt" "$ramsys_mnt" "$upperdir" "$workdir"

	if [ -z "${RAMSYSSRC}" ]; then
		panic "No squashfs source device specified. Boot arguments must include a ramsys.src= parameter."
	fi
	if [ -z "${RAMSYSDIR}" ]; then
		panic "No squashfs directory specified. Boot arguments must include a ramsys.dir= parameter."
	fi
	ramsys_dir_abs="${ramsys_src_mnt}/${RAMSYSDIR}"

	ramsys_device_setup "${RAMSYSSRC}" "ramsys.src file system"
	RAMSYS_SRC="${DEV}"

	# Get the root filesystem type if not set
	if [ -z "${RAMSYSSRCFSTYPE}" ] || [ "${RAMSYSSRCFSTYPE}" = auto ]; then
		FSTYPE=$(get_fstype "${RAMSYSSRC}")
	else
		FSTYPE=${RAMSYSSRCFSTYPE}
	fi

	ramsys_premount

	checkfs "${RAMSYSSRC}" "squashfs source" "${FSTYPE}"

	# Mount root
	# shellcheck disable=SC2086
	if ! mount -r ${FSTYPE:+-t "${FSTYPE}"} ${RAMSYSSRCFLAGS} "${RAMSYSSRC}" "${ramsys_src_mnt}"; then
		panic "Failed to mount ${RAMSYSSRC} (${FSTYPE}) as squashfs source file system."
	fi

	if ! [ -f "$ramsys_dir_abs" ]; then
		panic "Squashfs directory ${RAMSYSDIR} not found in ${RAMSYSSRC}"
	fi

	if ! cp -f "$ramsys_dir_abs" "${ramsys_dir_mem}"; then
		panic "Failed to load ${ramsys_dir_abs} into memory."
	fi
	chmod 400 "${ramsys_dir_mem}"
	umount "${ramsys_src_mnt}"

	if ! mount -t squashfs "${ramsys_dir_mem}" "$ramsys_mnt"; then
		panic "Failed to mount squashfs ${RAMSYSDIR} -> ${ramsys_dir_mem}"
	fi

	if [ "${readonly}" = "y" ]; then
		roflag=-r
	else
		roflag=-w
	fi

	local overlay_options="lowerdir=${ramsys_mnt},upperdir=${upperdir},workdir=${workdir}"
	if [ -z "${ROOTFLAGS}" ]; then
		ROOTFLAGS="-o ${overlay_options}"
	else
		ROOTFLAGS="${ROOTFLAGS},${overlay_options}"
	fi

	# Mount root
	# shellcheck disable=SC2086
	if ! mount ${roflag} -t overlay ${ROOTFLAGS} none "${rootmnt?}"; then
		panic "Failed to mount ${ROOT} as root file system."
	fi
	mkdir "${rootmnt}/.overlay-ro" && chmod 500 "${rootmnt}/.overlay-ro" || true
	mount -o bind "${upperdir}" "${rootmnt}/.overlay-ro" || true
	mount -r -o remount,ro,bind "${rootmnt}/.overlay-ro" "${rootmnt}/.overlay-ro" || true
}

mountroot()
{
	ramsys_mount_root
}

mount_top()
{
	# Note, also called directly in case it's overridden.
	ramsys_top
}

mount_premount()
{
	# Note, also called directly in case it's overridden.
	ramsys_premount
}

mount_bottom()
{
	# Note, also called directly in case it's overridden.
	ramsys_bottom
}
